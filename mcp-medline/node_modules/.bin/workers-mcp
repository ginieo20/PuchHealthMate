#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspace/mcp-medline/node_modules/.pnpm/workers-mcp@0.0.13/node_modules/workers-mcp/dist/node_modules:/workspace/mcp-medline/node_modules/.pnpm/workers-mcp@0.0.13/node_modules/workers-mcp/node_modules:/workspace/mcp-medline/node_modules/.pnpm/workers-mcp@0.0.13/node_modules:/workspace/mcp-medline/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspace/mcp-medline/node_modules/.pnpm/workers-mcp@0.0.13/node_modules/workers-mcp/dist/node_modules:/workspace/mcp-medline/node_modules/.pnpm/workers-mcp@0.0.13/node_modules/workers-mcp/node_modules:/workspace/mcp-medline/node_modules/.pnpm/workers-mcp@0.0.13/node_modules:/workspace/mcp-medline/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../workers-mcp/dist/cli.js" "$@"
else
  exec node  "$basedir/../workers-mcp/dist/cli.js" "$@"
fi
